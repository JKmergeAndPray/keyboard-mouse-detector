venv/
.venv/

<!-- # Python cache -->
__pycache__/
*.pyc

<!-- # Jupyter files -->
.ipynb_checkpoints/

<!-- # Git -->
.git/
.gitignore

<!-- # IDE -->
.vscode/

<!-- # OS files -->
.DS_Store
Thumbs.db

